/*
## notes ##
Front End App Service AGW
This template creates the following
 VNET with a /29 (8 IPs) in the 172.16.x.z/29 IP space: __appsvcVNET__
 - AGW subnet /29 (8 IPs)
 AGW V2 with WAF 
 - HTTPs bindings (443)
 - App service backend 
 REQUIRES SSL Certificate uploaded as 'secure file' in AZDO pipeline

For available VNETs, see: https://dev.azure.com/wtwdst/DevOps-Terraform/_git/Terraform?path=%2FScripts%2Fagw&version=GBscripts&_a=contents
vnets_in_use.txt

*/

# create random id for agw resources (KeyVault)
# using the 'dec' export; see https://www.terraform.io/docs/providers/random/r/id.html 
resource "random_id" "agw" {
  byte_length = 2
}
## NSG provisioning only. All rules should be handled via configuration files / Az CLI 
# This handles Azure app service tiers (app)
# must be provisioned before the subnet is
# agw nsg
# agw nsg for AGW v2 must have different defaults enabled.
resource "azurerm_network_security_group" "agw" {
  name                = "__appserviceplan__-nsgagw"
  location            = "__location__"
  resource_group_name = "__resourcegroupname__"
  tags = {
    "AppID" = "__AppID__"
    inventory = " {\"Product\":\"__productgroupshortname__\",\"Application\":\"__appcode__\",\"Environment\":\"__envName__\",\"Function\":\"nsg\"}"
  }
  
  # set the rules here. these have to override the default NSG to be compatible w/ AGW V2
  security_rule {
    name                       = "AllowAzureAGWv2"
    priority                   = 100
    direction                  = "Inbound"
    access                     = "Allow"
    protocol                   = "Tcp"
    source_port_range          = "*"
    destination_port_range     = "65200-65535"
    source_address_prefix      = "*"
    destination_address_prefix = "*"
  }
   security_rule {
    name                       = "AllowHTTP"
    priority                   = 200
    direction                  = "Inbound"
    access                     = "Allow"
    protocol                   = "Tcp"
    source_port_range          = "*"
    destination_port_range     = "80"
    source_address_prefix      = "*"
    destination_address_prefix = "*"
  }
  security_rule {
    name                       = "AllowHTTPS"
    priority                   = 210
    direction                  = "Inbound"
    access                     = "Allow"
    protocol                   = "Tcp"
    source_port_range          = "*"
    destination_port_range     = "443"
    source_address_prefix      = "*"
    destination_address_prefix = "*"
  }
  
}

## VNET and Subnets
# VNET is /28 8 IPs
resource "azurerm_virtual_network" "vnet" {
  name                = "${azurerm_app_service.tfweb__terraformlabel__.name}-network"
  resource_group_name = "__resourcegroupname__"
  location            = "__location__"
  address_space       = ["__appsvcVNET__/29"]
  tags = {
	  "AppID" = "__AppID__"
    inventory = " {\"Product\":\"__productgroupshortname__\",\"Application\":\"__appcode__\",\"Environment\":\"__envName__\",\"Function\":\"vnet\"}"
  }
}
# one AGW subnet only: /29 8 IPs
resource "azurerm_subnet" "agw" {
  name                 = "${azurerm_app_service.tfweb__terraformlabel__.name}-agw-subn"
  resource_group_name  = "__resourcegroupname__"
  virtual_network_name = "${azurerm_virtual_network.vnet.name}"
  address_prefix       = "__appsvcVNET__/29"
}
## NSG associations
# requires the subnets created first
resource "azurerm_subnet_network_security_group_association" "agw" {
  subnet_id                 = "${azurerm_subnet.agw.id}"
  network_security_group_id = "${azurerm_network_security_group.agw.id}"
}

resource "azurerm_public_ip" "pip" {
  name                = "${azurerm_app_service.tfweb__terraformlabel__.name}-pip"
  resource_group_name = "__resourcegroupname__"
  location            = "__location__"
  allocation_method   = "Static"
  sku                 = "Standard"
  # dns name is required for Azure Traffic Manager: https://docs.microsoft.com/en-us/azure/traffic-manager/traffic-manager-endpoint-types#azure-endpoints
  domain_name_label   = "${azurerm_app_service.tfweb__terraformlabel__.name}-pip"
  tags = {
	  "AppID" = "__AppID__"
    inventory = " {\"Product\":\"__productgroupshortname__\",\"Application\":\"__appcode__\",\"Environment\":\"__envName__\",\"Function\":\"web\"}"
  }
}

# since these variables are re-used - a locals block makes this more maintainable
locals {
  backend_address_pool_name      = "${azurerm_virtual_network.vnet.name}-beap"
  frontend_port_name_http        = "${azurerm_virtual_network.vnet.name}-fehttp"
  frontend_port_name_https       = "${azurerm_virtual_network.vnet.name}-fehttps"
  frontend_ip_configuration_name = "${azurerm_virtual_network.vnet.name}-feip"
  http_setting_name              = "${azurerm_virtual_network.vnet.name}-be-htst"
  listener_name_http             = "${azurerm_virtual_network.vnet.name}-httplstn"
  listener_name_https            = "${azurerm_virtual_network.vnet.name}-httpslstn"
  request_routing_rule_name      = "${azurerm_virtual_network.vnet.name}-rqrt"
  redirect_configuration_name    = "${azurerm_virtual_network.vnet.name}-rdrcfg"
  probe_name                     = "${azurerm_virtual_network.vnet.name}-probe"
  fqdn                           = "${azurerm_app_service.tfweb__terraformlabel__.name}.azurewebsites.net"
  ssl_cert_name                  = "__webAppCertificateName__"
}

resource "azurerm_application_gateway" "network" {
  name                = "${azurerm_app_service.tfweb__terraformlabel__.name}-agw"
  resource_group_name = "__resourcegroupname__"
  location            = "__location__"
  tags = {
	  "AppID" = "__AppID__"
    inventory = " {\"Product\":\"__productgroupshortname__\",\"Application\":\"__appcode__\",\"Environment\":\"__envName__\",\"Function\":\"web\"}"
  }
  sku {
    name     = "WAF_v2"
    tier     = "WAF_v2"
    capacity = "__agw_capacity__"
  }
  waf_configuration { 
    firewall_mode    =  "Prevention" // "Detection"
    rule_set_type    = "OWASP"
    rule_set_version = "3.0"
    enabled          = true
  }

  gateway_ip_configuration {
    name      = "${azurerm_app_service.tfweb__terraformlabel__.name}-agw-ip-cfg"
    subnet_id = "${azurerm_subnet.agw.id}"
  }

  frontend_ip_configuration {
    name                 = "${local.frontend_ip_configuration_name}"
    public_ip_address_id = "${azurerm_public_ip.pip.id}"
  }

   frontend_port {
    name = "${local.frontend_port_name_http}"
	  port = 80
  }
  frontend_port {
    name = "${local.frontend_port_name_https}"
	  port = 443
  }
  probe {
    name                = "${local.probe_name}"
    interval            = "30"
    protocol            = "Https"
    path                = "__agwMontiorProbe__"
    timeout             = "120"
	  unhealthy_threshold = "3"
	  pick_host_name_from_backend_http_settings = "true"
	  match  {
	    status_code       = ["200-399"]
	  }
	
  }

  backend_address_pool {
    name  = "${local.backend_address_pool_name}"
	  fqdns = ["${local.fqdn}"]
  }

  backend_http_settings {
    name                  = "${local.http_setting_name}"
    cookie_based_affinity = "Disabled"
    port                  = 443
    protocol              = "Https"
    request_timeout       = 120
	  pick_host_name_from_backend_address = "true"
	
  }
  # http listener is only redirect
  http_listener {
    name                           = "${local.listener_name_http}"
    frontend_ip_configuration_name = "${local.frontend_ip_configuration_name}"
    frontend_port_name             = "${local.frontend_port_name_http}"
    protocol                       = "Http"
  }

# region: use this ONLY for testing - this will expose HTTP 80 requests to backend pool
  request_routing_rule {
    name                       = "${local.request_routing_rule_name}"
    rule_type                  = "Basic"
    http_listener_name         = "${local.listener_name_http}"
    backend_address_pool_name  = "${local.backend_address_pool_name}"
    backend_http_settings_name = "${local.http_setting_name}"
  }
# endregion

/* 
# region: SSL certificate required
#  Https listener needs SSL Certificate. Currently, TF doesn't support AGW V2 + KeyVault integration
 ssl_certificate {
     name     = "${local.ssl_cert_name}"
     data     = "__webAppCertificateData__"
     password = "__webAppCertificatePW__"
  }
  http_listener {
    name                           = "${local.listener_name_https}"
    frontend_ip_configuration_name = "${local.frontend_ip_configuration_name}"
    frontend_port_name             = "${local.frontend_port_name_https}"
	  protocol                       = "Https"
	  ssl_certificate_name           = "${local.ssl_cert_name}"
  }

  request_routing_rule {
    name                       = "${local.request_routing_rule_name}"
    rule_type                  = "Basic"
    http_listener_name         = "${local.listener_name_https}"
    backend_address_pool_name  = "${local.backend_address_pool_name}"
    backend_http_settings_name = "${local.http_setting_name}"
  }
  # http to https redirect
  redirect_configuration {
    name                       = "http-to-https-redirect"
    redirect_type              = "Permanent"
    include_path               = true
    include_query_string       = true
    target_listener_name       = "${local.listener_name_https}"
  }
  request_routing_rule {
    name                       = "http-to-https-requests"
    rule_type                  = "Basic"
    http_listener_name         = "${local.listener_name_http}"
    redirect_configuration_name = "http-to-https-redirect"
  }
# end region: SSL certificate  
*/

  /* PLACEHOLDER: save the agw_fe_ip for app service config (future state)
  output "agw_fe_ip" { 
    value = azurerm_application_gateway.network.frontend_ip_configuration 
  }
  */
}

# agw user assigned identity - this will be handled via script to add to KeyVault resource group instead
resource "azurerm_user_assigned_identity" "agwkvid" {
  # not sure why 'convention' name doesn't work.. using the random id instead
  # could be the 24 character KeyVault max name length
  # name               = "${azurerm_application_gateway.network.name}-kvid"
  name                = "agwkvid-${random_id.agw.dec}"
  resource_group_name = "__resourcegroupname__"
  location            = "__location__"
}
