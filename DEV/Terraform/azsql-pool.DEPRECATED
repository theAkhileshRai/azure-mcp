## assumes Portal (DNN) SQL server and elastic pool previously created
# create 'Configuration' database
resource "azurerm_sql_database" "configuration" {
  server_name         = "__sql_server_name__"
  elastic_pool_name   = "__sql_elasticpool_name__"
  name                = "Configuration"
  resource_group_name = "__resource_group_name__"
  location            = "__location__"
  
  tags = {
    "AppID" = "__AppID__"
  }
}